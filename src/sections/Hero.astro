---
import { my_information } from "@/scripts/information";

const infoHero = my_information.hero;
---

<section
  class="hero grid grid-cols-1 md:grid-cols-[1fr_1.5fr] w-full max-w-6xl mx-auto p-4 items-center gap-y-10"
>
  <article class="space-y-8">
    <p
      class="rounded-full px-3 py-1 text-gray-400 border border-gray-700 w-max text-xs md:text-sm"
    >
      <span
        class="size-2 inline-block bg-green-500 animate-pulse rounded-full mr-1"
      ></span>
      <span>{infoHero.availability}</span>
    </p>
    <div class="body space-y-4">
      <p class="text-lg">
        <span>{infoHero.welcome}</span>
        <span class="text-blue-300">{infoHero.name}! 👋</span>
      </p>
      <h1 class="font-bold text-title text-balance">{infoHero.position}</h1>
      <p class="text-gray-400 text-pretty">{infoHero.description}</p>
    </div>
    <div class="flex items-center gap-3 mt-4">
      {
        infoHero.buttons_cta.map((btn) => (
          <a href={btn.url} class:list={["btn", btn.class_type]}>
            <btn.icon />
            {btn.text}
          </a>
        ))
      }
    </div>
  </article>
  <article class="w-full rounded-2xl flex justify-center items-center">
    <figure>
      <img
        class="block object-cover w-full"
        src="images/image-hero.webp"
        alt="imagen hero"
      />
    </figure>
  </article>
</section>

<style>
  .text-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.2;
  }
</style>
