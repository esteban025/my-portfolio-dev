---
import { my_information } from "@/scripts/information";
const ftIf = my_information.footer;
---

<footer
  class="p-4 border-t border-gray-700 flex items-center justify-between gap-2 text-xs text-gray-500 text-balance"
>
  <div class="">
    <p>{ftIf.copyright}</p>
    <p>{ftIf.phrase}</p>
  </div>
  <ul class="flex items-center gap-2">
    {
      ftIf.social_links.map((sn) => (
        <li>
          <a href={sn.url} class="btn btn-square">
            <sn.icon />
          </a>
        </li>
      ))
    }
  </ul>
</footer>
